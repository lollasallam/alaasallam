{
  "entities": {
    "DimensionScore": {
      "title": "Dimension Score",
      "description": "Score for a specific dimension",
      "type": "object",
      "properties": {
        "dimensionTitle": { "type": "string" },
        "score": { "type": "number" },
        "maxScore": { "type": "number" },
        "percentage": { "type": "number" }
      },
      "required": ["dimensionTitle", "score", "maxScore", "percentage"]
    },
    "Submission": {
      "title": "Survey Submission",
      "description": "A student's survey submission",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "studentName": { "type": "string" },
        "school": { "type": "string" },
        "grade": { "type": "string" },
        "timestamp": { "type": "string" },
        "totalScore": { "type": "number" },
        "maxTotalScore": { "type": "number" },
        "dimensionScores": {
          "type": "array",
          "items": { "$ref": "#/entities/DimensionScore" }
        },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["userId", "studentName", "school", "grade", "timestamp", "totalScore", "maxTotalScore", "dimensionScores", "createdAt"]
    }
  },
  "firestore": {
    "/submissions/{submissionId}": {
      "schema": "#/entities/Submission",
      "description": "Stores survey submissions by students"
    }
  }
}
