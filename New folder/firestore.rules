rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Primitives
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isResearcher() { 
      return isSignedIn() && 
             request.auth.token.email == 'lollasallam@gmail.com'; 
    }
    function isOwner() { return isSignedIn() && existing().userId == request.auth.uid; }
    
    match /submissions/{submissionId} {
      allow read, list: if isResearcher();
      
      allow create: if isSignedIn() 
        && dataIsValid(incoming())
        && isValidId(submissionId)
        && incoming().userId == request.auth.uid;
        
      allow update: if (isResearcher()
        && dataIsValid(incoming())
      );
      
      allow delete: if isResearcher();
    }
    
    function dataIsValid(data) {
      return data.keys().hasAll(['userId', 'studentName', 'school', 'grade', 'timestamp', 'totalScore', 'maxTotalScore', 'dimensionScores', 'createdAt'])
        && data.keys().size() == 9
        && data.userId is string && data.userId.size() <= 128
        && data.studentName is string && data.studentName.size() <= 200
        && data.school is string && data.school.size() <= 200
        && data.grade is string && data.grade.size() <= 200
        && data.timestamp is string && data.timestamp.size() <= 100
        && data.totalScore is number
        && data.maxTotalScore is number
        && data.dimensionScores is list
        && data.dimensionScores.size() <= 20
        && data.createdAt == request.time;
    }
  }
}
